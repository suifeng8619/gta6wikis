---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumb from '../../components/layout/Breadcrumb.astro';
import InfoBox from '../../components/wiki/InfoBox.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import { generateCanonical, SITE_URL } from '../../utils/seo';

export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getCollection('series');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
};

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

const canonicalUrl = generateCanonical(`/series/${entry.id}`);
const pageTitle = `${data.title} - GTA Series | GTA6 Wikis`;

const infoFields = [
  { label: 'Release Date', value: data.releaseDate },
  { label: 'Developer', value: data.developer },
  { label: 'Publisher', value: data.publisher },
  { label: 'Platforms', value: data.platforms.join(', ') },
  { label: 'Protagonist', value: data.protagonist },
  { label: 'City', value: data.city },
  { label: 'Setting', value: data.setting },
  ...(data.metacriticScore !== undefined
    ? [{ label: 'Metacritic', value: `${data.metacriticScore}/100` }]
    : []
  ),
  ...(data.salesData ? [{ label: 'Sales', value: data.salesData }] : []),
];
---

<BaseLayout
  title={pageTitle}
  description={data.description}
  image={data.image}
  canonicalUrl={canonicalUrl}
  type="article"
>
  <JsonLd
    type="Article"
    data={{
      headline: pageTitle,
      description: data.description,
      image: data.image.startsWith('http') ? data.image : `${SITE_URL}${data.image}`,
      datePublished: data.datePublished.toISOString(),
      dateModified: (data.dateModified ?? data.datePublished).toISOString(),
      url: canonicalUrl,
    }}
  />

  <div class="detail-page">
    <div class="detail-page__container">
      <Breadcrumb
        items={[
          { label: 'GTA Series', href: '/series/' },
          { label: data.title },
        ]}
      />

      <article class="detail-page__article">
        <h1 class="detail-page__title">{data.title}</h1>

        <div class="detail-page__body">
          <!-- InfoBox floated right -->
          <InfoBox
            title={data.title}
            image={data.image}
            imageAlt={data.imageAlt}
            fields={infoFields}
          />

          <!-- Metacritic score badge (if available) -->
          {data.metacriticScore !== undefined && (
            <div class="meta-badge-wrap">
              <div
                class={`meta-badge ${data.metacriticScore >= 90 ? 'meta-badge--green' : data.metacriticScore >= 75 ? 'meta-badge--yellow' : 'meta-badge--red'}`}
                aria-label={`Metacritic score: ${data.metacriticScore} out of 100`}
              >
                <span class="meta-badge__score">{data.metacriticScore}</span>
                <span class="meta-badge__label">Metacritic</span>
              </div>
            </div>
          )}

          <!-- Main content -->
          <div class="detail-page__content prose">
            <Content />
          </div>
        </div>
      </article>
    </div>
  </div>
</BaseLayout>

<style>
  .detail-page {
    padding: 0 0 3rem;
  }

  .detail-page__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .detail-page__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--text-primary);
    margin: 1rem 0 1.5rem;
    line-height: 1.2;
    letter-spacing: 0.02em;
  }

  .detail-page__body {
    position: relative;
  }

  /* Metacritic badge */
  .meta-badge-wrap {
    display: inline-block;
    margin: 0 0 1.5rem;
  }

  .meta-badge {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 80px;
    height: 80px;
    border-radius: 8px;
    border: 3px solid currentColor;
  }

  .meta-badge--green {
    background: #1a3a1a;
    color: #6cc644;
    border-color: #6cc644;
  }

  .meta-badge--yellow {
    background: #3a3a1a;
    color: #f0a30a;
    border-color: #f0a30a;
  }

  .meta-badge--red {
    background: #3a1a1a;
    color: #e05252;
    border-color: #e05252;
  }

  .meta-badge__score {
    font-family: var(--font-heading);
    font-size: 2rem;
    font-weight: 700;
    line-height: 1;
  }

  .meta-badge__label {
    font-size: 0.6rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.8;
    margin-top: 2px;
  }

  /* Prose styles */
  .detail-page__content :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 2rem 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-primary);
    letter-spacing: 0.02em;
    scroll-margin-top: 80px;
  }

  .detail-page__content :global(h3) {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 1.5rem 0 0.5rem;
    scroll-margin-top: 80px;
  }

  .detail-page__content :global(h4) {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 1.25rem 0 0.5rem;
    scroll-margin-top: 80px;
  }

  .detail-page__content :global(p) {
    color: var(--text-secondary);
    line-height: 1.75;
    margin: 0 0 1rem;
  }

  .detail-page__content :global(ul),
  .detail-page__content :global(ol) {
    color: var(--text-secondary);
    line-height: 1.75;
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }

  .detail-page__content :global(li) {
    margin-bottom: 0.25rem;
  }

  .detail-page__content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .detail-page__content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity 0.2s;
  }

  .detail-page__content :global(a:hover) {
    opacity: 0.8;
  }

  .detail-page__content :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    padding: 0.5rem 1rem;
    margin: 1rem 0;
    background: var(--bg-surface);
    border-radius: 0 6px 6px 0;
  }

  .detail-page__content :global(blockquote p) {
    margin: 0;
    font-style: italic;
  }

  .detail-page__content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9rem;
    overflow-x: auto;
    display: block;
  }

  .detail-page__content :global(th) {
    background: var(--bg-tertiary);
    color: var(--text-primary);
    font-weight: 600;
    padding: 10px 14px;
    text-align: left;
    border: 1px solid var(--border-default);
  }

  .detail-page__content :global(td) {
    padding: 8px 14px;
    border: 1px solid var(--border-default);
    color: var(--text-secondary);
    vertical-align: top;
  }

  .detail-page__content :global(tr:nth-child(even) td) {
    background: var(--bg-surface);
  }

  @media (max-width: 640px) {
    .detail-page__container {
      padding: 0 1rem;
    }
  }
</style>
