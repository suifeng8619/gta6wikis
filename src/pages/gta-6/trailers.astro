---
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumb from '../../components/layout/Breadcrumb.astro';
import AlertBox from '../../components/wiki/AlertBox.astro';
import YouTubeEmbed from '../../components/ui/YouTubeEmbed.astro';
---

<BaseLayout
  title="GTA 6 Trailers - Complete Analysis | GTA6 Wikis"
  description="Full analysis of GTA 6 Trailer 1 and Trailer 2 — confirmed characters, locations, vehicles, records, and every detail revealed."
  canonicalUrl="https://gta6wikis.com/gta-6/trailers/"
>
  <div class="page-wrapper">
    <div class="container">
      <Breadcrumb items={[
        { label: 'GTA 6', href: '/gta-6/' },
        { label: 'Trailers' }
      ]} />
    </div>

    <header class="page-header">
      <div class="container">
        <h1 class="page-header__title">GTA 6 Trailers</h1>
        <p class="page-header__desc">Complete analysis of every officially released GTA 6 trailer, including records broken, confirmed gameplay elements, and scene-by-scene breakdowns.</p>
      </div>
    </header>

    <div class="container main-content">

      <!-- Trailer 1 -->
      <section id="trailer-1" class="trailer-section" aria-labelledby="t1-heading">
        <div class="trailer-header">
          <span class="trailer-badge">Trailer 1</span>
          <h2 class="trailer-title" id="t1-heading">Grand Theft Auto VI — Official Trailer 1</h2>
          <div class="trailer-meta">
            <span><strong>Released:</strong> December 4, 2023</span>
            <span><strong>Duration:</strong> 91 seconds</span>
            <span><strong>Music:</strong> Tom Petty — "Love Is a Long Road"</span>
          </div>
        </div>

        <!-- YouTube embed — Trailer 1 -->
        <YouTubeEmbed
          videoId="QdBZExpgErs"
          title="Grand Theft Auto VI — Official Trailer 1"
        />

        <!-- Records -->
        <div class="subsection">
          <h3 class="subsection__title">Record-Breaking Performance</h3>
          <div class="stats-grid">
            <div class="stat-card">
              <span class="stat-card__num">46M</span>
              <span class="stat-card__label">Views in 12 hours</span>
              <span class="stat-card__note">Non-music video record at time of release</span>
            </div>
            <div class="stat-card">
              <span class="stat-card__num">93M</span>
              <span class="stat-card__label">Views in 24 hours</span>
              <span class="stat-card__note">#3 overall debut at time of release</span>
            </div>
            <div class="stat-card">
              <span class="stat-card__num">8.9M</span>
              <span class="stat-card__label">Likes</span>
              <span class="stat-card__note">Most-liked gaming trailer on YouTube</span>
            </div>
            <div class="stat-card">
              <span class="stat-card__num">269M</span>
              <span class="stat-card__label">Total views</span>
              <span class="stat-card__note">As of November 2025</span>
            </div>
          </div>
          <p class="note-text">Trailer 1 earned a Guinness World Record for most-viewed videogame trailer in 24 hours, surpassing MrBeast's "Every Country On Earth Fights for $250,000" (59.4M views in 24 hours, August 2023).</p>
        </div>

        <!-- Music -->
        <div class="subsection">
          <h3 class="subsection__title">Music Impact</h3>
          <p>The trailer used Tom Petty's "Love Is a Long Road" from the 1989 album <em>Full Moon Fever</em>, originally released as the B-side to "Free Fallin'." Tom Petty was a native of Florida — a deliberate thematic connection to the Leonida/Florida setting. Following the trailer's release:</p>
          <ul class="detail-list">
            <li>Spotify streams increased by <strong>36,979%</strong> in one week</li>
            <li>Approximately 250,000 Shazam searches</li>
            <li>Reached #2 on iTunes globally</li>
          </ul>
        </div>

        <!-- Key Scenes -->
        <div class="subsection">
          <h3 class="subsection__title">Key Scenes and Confirmed Details</h3>
          <ul class="detail-list">
            <li>Vice City setting confirmed — Miami-inspired coastal city</li>
            <li>Lucia Caminos introduced wearing an ankle monitor (on parole)</li>
            <li>Jason Duval seen driving a light blue Vapid vehicle to pick up Lucia</li>
            <li>Art Deco hotels along Ocean Drive visible (Loews, Royal Palm equivalents)</li>
            <li>Social media integration shown — in-world "Finger" posts mimicking TikTok and Instagram Live</li>
            <li>Florida-inspired events: alligator in a convenience store, woman dancing on a moving car</li>
            <li>Malibu Club reference (original Vice City location)</li>
            <li>Seven Mile Bridge visible — first time it can be fully traversed in a GTA game</li>
            <li>Cage fighting scene with Lucia — demonstrating combat system</li>
            <li>Jason bench pressing 265 lbs — suggests a returning body stat system</li>
            <li>"Petty Forever" sticker at 1:17 — tribute to Tom Petty</li>
            <li>Scarface building visible (three circular windows)</li>
          </ul>
        </div>

        <!-- Easter Eggs -->
        <div class="subsection">
          <h3 class="subsection__title">Notable Easter Eggs</h3>
          <ul class="detail-list">
            <li><strong>Phil Cassidy reference:</strong> A character matching Phil Cassidy (from GTA III era) appears in a gun shop TV advertisement — with both arms, sparking fan theories about him being Phil Cassidy Jr. or a franchise reboot character.</li>
            <li><strong>RDR2 currency:</strong> Bills in the trailer feature names (Thaddeus Waxman, Franklin Hardin) also found in Red Dead Redemption 2.</li>
            <li><strong>Dynamic hair growth:</strong> Jason's beard and hair length varies across different frames, suggesting the return of RDR2's hair growth system.</li>
            <li><strong>Animals confirmed:</strong> Chihuahua, flamingo, alligator, dolphin visible.</li>
          </ul>
        </div>
      </section>

      <!-- Trailer 2 -->
      <section id="trailer-2" class="trailer-section" aria-labelledby="t2-heading">
        <div class="trailer-header">
          <span class="trailer-badge trailer-badge--t2">Trailer 2</span>
          <h2 class="trailer-title" id="t2-heading">Grand Theft Auto VI — Official Trailer 2</h2>
          <div class="trailer-meta">
            <span><strong>Released:</strong> May 6, 2025</span>
            <span><strong>Wait from Trailer 1:</strong> 380+ days (longest gap in Rockstar history)</span>
          </div>
        </div>

        <!-- YouTube embed — Trailer 2 -->
        <YouTubeEmbed
          videoId="VQRLujxTm3c"
          title="Grand Theft Auto VI — Official Trailer 2"
        />

        <!-- Records -->
        <div class="subsection">
          <h3 class="subsection__title">Record-Breaking Performance</h3>
          <div class="stats-grid">
            <div class="stat-card stat-card--highlight">
              <span class="stat-card__num">475M</span>
              <span class="stat-card__label">Views in 24 hours (all platforms)</span>
              <span class="stat-card__note">Biggest video debut of all time, surpassing Deadpool &amp; Wolverine</span>
            </div>
          </div>
          <AlertBox type="tip" title="Historic Record">
            Trailer 2 set the all-time record for the biggest video debut across all platforms in a single 24-hour period, surpassing the previous record held by the Deadpool &amp; Wolverine trailer.
          </AlertBox>
        </div>

        <!-- Key Reveals -->
        <div class="subsection">
          <h3 class="subsection__title">Key Reveals in Trailer 2</h3>
          <ul class="detail-list">
            <li>Full names revealed: <strong>Lucia Caminos</strong> and <strong>Jason Duval</strong></li>
            <li>Detailed character backstories shown for both protagonists</li>
            <li>Expanded Vice City footage with more city districts and rural areas</li>
            <li>More story context — the Bonnie-and-Clyde criminal partnership structure</li>
            <li>Jason's military background confirmed through tattoos and combat stance</li>
            <li>GTA Online 2 teased through expanded multiplayer scenes</li>
          </ul>
        </div>
      </section>

      <!-- Confirmed Game Elements -->
      <section id="confirmed" class="section" aria-labelledby="confirmed-heading">
        <h2 class="section__title" id="confirmed-heading">Confirmed Game Elements from Both Trailers</h2>
        <div class="confirmed-grid">
          <div class="confirmed-category">
            <h3 class="confirmed-category__title">Locations</h3>
            <ul class="confirmed-list">
              <li>Vice City (main city)</li>
              <li>Leonida Keys (island chain)</li>
              <li>Grassrivers (rural/swamp)</li>
              <li>Port Gellhorn</li>
              <li>Ambrosia (biker territory)</li>
              <li>Mount Kalaga</li>
              <li>VCI Airport</li>
              <li>Seven Mile Bridge</li>
              <li>NINE 1 ELEVEN Nightclub</li>
            </ul>
          </div>
          <div class="confirmed-category">
            <h3 class="confirmed-category__title">Vehicles</h3>
            <ul class="confirmed-list">
              <li>Sports cars (Cheetah)</li>
              <li>Pick-up trucks</li>
              <li>Motorcycles</li>
              <li>Speed boats &amp; jet skis</li>
              <li>Helicopters (Maverick)</li>
              <li>Dodo seaplane</li>
              <li>Yachts &amp; cruise ships</li>
              <li>Monster trucks</li>
              <li>Amphibious vehicles</li>
            </ul>
          </div>
          <div class="confirmed-category">
            <h3 class="confirmed-category__title">Characters &amp; World</h3>
            <ul class="confirmed-list">
              <li>Lucia Caminos (protagonist)</li>
              <li>Jason Duval (protagonist)</li>
              <li>In-world social media "Finger"</li>
              <li>Phil Cassidy reference</li>
              <li>Florida Man cultural references</li>
              <li>Alligators &amp; flamingos</li>
              <li>Dynamic NPC AI behaviors</li>
              <li>Body stat system</li>
            </ul>
          </div>
          <div class="confirmed-category">
            <h3 class="confirmed-category__title">Technology</h3>
            <ul class="confirmed-list">
              <li>Ray-traced global illumination</li>
              <li>Ray-traced reflections</li>
              <li>RAGE 9 engine</li>
              <li>First-person vehicle interiors</li>
              <li>Beer bottle condensation detail</li>
              <li>Puddle surface reflections</li>
              <li>Dynamic hair growth system</li>
              <li>Social media integration</li>
            </ul>
          </div>
        </div>
      </section>

    </div>
  </div>
</BaseLayout>

<style>
  .page-wrapper {
    min-height: 100vh;
  }

  .container {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Page Header */
  .page-header {
    background: linear-gradient(160deg, var(--bg-secondary) 0%, var(--bg-primary) 100%);
    border-bottom: 1px solid var(--border-color);
    padding: 2.5rem 0;
  }

  .page-header__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(2.5rem, 7vw, 4.5rem);
    color: var(--text-primary);
    margin: 0 0 0.5rem;
    letter-spacing: 0.04em;
  }

  .page-header__desc {
    color: var(--text-secondary);
    font-size: 1rem;
    line-height: 1.6;
    margin: 0;
    max-width: 680px;
  }

  /* Main */
  .main-content {
    padding: 2.5rem 0 3rem;
  }

  /* Trailer section */
  .trailer-section {
    margin-bottom: 3.5rem;
    padding-bottom: 3rem;
    border-bottom: 2px solid var(--border-color);
  }

  .trailer-section:last-of-type {
    border-bottom: none;
  }

  .trailer-header {
    margin-bottom: 1.5rem;
  }

  .trailer-badge {
    display: inline-block;
    padding: 3px 10px;
    background: rgba(255, 94, 77, 0.15);
    color: var(--color-accent);
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    border-radius: 4px;
    margin-bottom: 0.5rem;
  }

  .trailer-badge--t2 {
    background: rgba(255, 160, 0, 0.15);
    color: var(--color-warning);
  }

  .trailer-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2rem;
    letter-spacing: 0.04em;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
  }

  .trailer-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    font-size: 0.85rem;
    color: var(--text-secondary);
  }

  .trailer-meta strong {
    color: var(--text-primary);
  }

  /* Stats grid */
  .stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1rem;
    margin: 1rem 0 1.5rem;
  }

  .stat-card {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 1.25rem 1rem;
  }

  .stat-card--highlight {
    border-color: var(--color-accent);
    background: rgba(255, 94, 77, 0.05);
  }

  .stat-card__num {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.25rem;
    color: var(--color-accent);
    line-height: 1;
    margin-bottom: 0.35rem;
  }

  .stat-card__label {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 0.35rem;
  }

  .stat-card__note {
    font-size: 0.725rem;
    color: var(--text-muted);
    line-height: 1.4;
  }

  /* Subsections */
  .subsection {
    margin: 2rem 0;
  }

  .subsection__title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.875rem;
    padding-bottom: 0.5rem;
    border-bottom: 1px solid var(--border-color);
  }

  .subsection p {
    color: var(--text-secondary);
    line-height: 1.75;
    margin-bottom: 0.75rem;
    font-size: 0.9rem;
  }

  .note-text {
    font-size: 0.85rem;
    color: var(--text-muted);
    line-height: 1.65;
    font-style: italic;
  }

  /* Detail lists */
  .detail-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .detail-list li {
    position: relative;
    padding-left: 1.25rem;
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  .detail-list li::before {
    content: '→';
    position: absolute;
    left: 0;
    color: var(--color-accent);
    font-size: 0.8rem;
    top: 0.05em;
  }

  .detail-list li strong {
    color: var(--text-primary);
  }

  /* Confirmed Grid */
  .section {
    margin-bottom: 3rem;
  }

  .section__title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.875rem;
    letter-spacing: 0.04em;
    color: var(--text-primary);
    margin: 0 0 1.25rem;
  }

  .confirmed-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(210px, 1fr));
    gap: 1.25rem;
  }

  .confirmed-category {
    background: var(--bg-card);
    border: 1px solid var(--border-color);
    border-radius: 10px;
    padding: 1.25rem;
  }

  .confirmed-category__title {
    font-size: 0.875rem;
    font-weight: 700;
    color: var(--color-accent);
    margin: 0 0 0.875rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 0.75rem;
  }

  .confirmed-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .confirmed-list li {
    font-size: 0.825rem;
    color: var(--text-secondary);
    padding-left: 1rem;
    position: relative;
    line-height: 1.4;
  }

  .confirmed-list li::before {
    content: '•';
    position: absolute;
    left: 0;
    color: var(--text-muted);
  }

  @media (max-width: 600px) {
    .stats-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .trailer-meta {
      flex-direction: column;
      gap: 0.4rem;
    }
  }
</style>
