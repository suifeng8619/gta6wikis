---
import { getCollection, render } from 'astro:content';
import type { GetStaticPaths } from 'astro';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumb from '../../components/layout/Breadcrumb.astro';
import InfoBox from '../../components/wiki/InfoBox.astro';
import RelatedPages from '../../components/wiki/RelatedPages.astro';
import JsonLd from '../../components/seo/JsonLd.astro';
import { generateCanonical, SITE_URL } from '../../utils/seo';

export const getStaticPaths: GetStaticPaths = async () => {
  const entries = await getCollection('characters');
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
};

const { entry } = Astro.props;
const { Content } = await render(entry);
const data = entry.data;

const canonicalUrl = generateCanonical(`/characters/${entry.id}`);
const pageTitle = `${data.title} - GTA 6 Character | GTA6 Wikis`;

const genderLabel = data.gender === 'male' ? 'Male' : data.gender === 'female' ? 'Female' : 'Unknown';
const roleLabel = data.role.charAt(0).toUpperCase() + data.role.slice(1);
const statusLabel = data.status.charAt(0).toUpperCase() + data.status.slice(1);

const infoFields = [
  { label: 'Full Name', value: data.fullName },
  { label: 'Gender', value: genderLabel },
  { label: 'Race', value: data.race },
  { label: 'Nationality', value: data.nationality },
  { label: 'Age', value: data.age },
  { label: 'Voice Actor', value: data.voiceActor },
  { label: 'Role', value: roleLabel },
  { label: 'Affiliation', value: data.affiliation },
  { label: 'First Appearance', value: data.firstAppearance },
  { label: 'Status', value: statusLabel },
];

// Related characters (exclude current)
const allCharacters = await getCollection('characters');
const related = allCharacters
  .filter((c) => c.id !== entry.id)
  .slice(0, 6)
  .map((c) => ({
    title: c.data.title,
    href: `/characters/${c.id}/`,
    image: c.data.image,
    category: 'Character',
  }));
---

<BaseLayout
  title={pageTitle}
  description={data.description}
  image={data.image}
  canonicalUrl={canonicalUrl}
  type="article"
>
  <JsonLd
    type="Person"
    data={{
      name: data.title,
      description: data.description,
      url: canonicalUrl,
      image: data.image.startsWith('http') ? data.image : `${SITE_URL}${data.image}`,
    }}
  />

  <div class="detail-page">
    <div class="detail-page__container">
      <Breadcrumb
        items={[
          { label: 'Characters', href: '/characters/' },
          { label: data.title },
        ]}
      />

      <article class="detail-page__article" itemscope itemtype="https://schema.org/Person">
        <h1 class="detail-page__title" itemprop="name">{data.title}</h1>

        <div class="detail-page__body">
          <!-- InfoBox floated right -->
          <InfoBox
            title={data.title}
            image={data.image}
            imageAlt={data.imageAlt}
            fields={infoFields}
          />

          <!-- Main content -->
          <div class="detail-page__content prose" itemprop="description">
            <Content />
          </div>
        </div>
      </article>

      {related.length > 0 && (
        <div class="detail-page__related">
          <RelatedPages pages={related} heading="Related Characters" />
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .detail-page {
    padding: 0 0 3rem;
  }

  .detail-page__container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  .detail-page__title {
    font-family: var(--font-heading);
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 700;
    color: var(--text-primary);
    margin: 1rem 0 1.5rem;
    line-height: 1.2;
    letter-spacing: 0.02em;
  }

  .detail-page__body {
    position: relative;
  }

  .detail-page__content {
    /* Prose styles for rendered Markdown */
  }

  /* Prose typography */
  .detail-page__content :global(h2) {
    font-family: var(--font-heading);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 2rem 0 0.75rem;
    padding-bottom: 0.5rem;
    border-bottom: 2px solid var(--color-primary);
    letter-spacing: 0.02em;
    scroll-margin-top: 80px;
  }

  .detail-page__content :global(h3) {
    font-family: var(--font-heading);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 1.5rem 0 0.5rem;
    scroll-margin-top: 80px;
  }

  .detail-page__content :global(h4) {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin: 1.25rem 0 0.5rem;
    scroll-margin-top: 80px;
  }

  .detail-page__content :global(p) {
    color: var(--text-secondary);
    line-height: 1.75;
    margin: 0 0 1rem;
  }

  .detail-page__content :global(ul),
  .detail-page__content :global(ol) {
    color: var(--text-secondary);
    line-height: 1.75;
    margin: 0 0 1rem;
    padding-left: 1.5rem;
  }

  .detail-page__content :global(li) {
    margin-bottom: 0.25rem;
  }

  .detail-page__content :global(strong) {
    color: var(--text-primary);
    font-weight: 600;
  }

  .detail-page__content :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
    text-underline-offset: 2px;
    transition: opacity 0.2s;
  }

  .detail-page__content :global(a:hover) {
    opacity: 0.8;
  }

  .detail-page__content :global(blockquote) {
    border-left: 4px solid var(--color-primary);
    padding: 0.5rem 1rem;
    margin: 1rem 0;
    background: var(--bg-surface);
    border-radius: 0 6px 6px 0;
  }

  .detail-page__content :global(blockquote p) {
    margin: 0;
    font-style: italic;
    color: var(--text-secondary);
  }

  .detail-page__content :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 1rem 0;
    font-size: 0.9rem;
    overflow-x: auto;
    display: block;
  }

  .detail-page__content :global(th) {
    background: var(--bg-tertiary);
    color: var(--text-primary);
    font-weight: 600;
    padding: 10px 14px;
    text-align: left;
    border: 1px solid var(--border-default);
  }

  .detail-page__content :global(td) {
    padding: 8px 14px;
    border: 1px solid var(--border-default);
    color: var(--text-secondary);
    vertical-align: top;
  }

  .detail-page__content :global(tr:nth-child(even) td) {
    background: var(--bg-surface);
  }

  .detail-page__content :global(code) {
    background: var(--bg-tertiary);
    padding: 0.15em 0.4em;
    border-radius: 4px;
    font-size: 0.875em;
    color: var(--color-primary);
  }

  .detail-page__related {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border-default);
    clear: both;
  }

  @media (max-width: 640px) {
    .detail-page__container {
      padding: 0 1rem;
    }

    .detail-page__title {
      margin: 0.75rem 0 1rem;
    }
  }
</style>
