---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumb from '../../components/layout/Breadcrumb.astro';
import CategoryNav from '../../components/wiki/CategoryNav.astro';
import Icon from '../../components/ui/Icon.astro';

const allWeapons = await getCollection('weapons');
allWeapons.sort((a, b) => a.data.title.localeCompare(b.data.title));

const filterParam = Astro.url.searchParams.get('type') ?? 'all';

const typeLabels: Record<string, string> = {
  pistol: 'Pistols',
  smg: 'SMGs',
  'assault-rifle': 'Assault Rifles',
  shotgun: 'Shotguns',
  'sniper-rifle': 'Snipers',
  lmg: 'LMGs',
  melee: 'Melee',
  throwable: 'Throwables',
  heavy: 'Heavy',
  special: 'Special',
};

const typeIcons: Record<string, string> = {
  pistol: 'pistol',
  smg: 'smg',
  'assault-rifle': 'assault-rifle',
  shotgun: 'shotgun',
  'sniper-rifle': 'sniper-rifle',
  lmg: 'lmg',
  melee: 'melee',
  throwable: 'throwable',
  heavy: 'heavy',
  special: 'special',
};

const categoryCounts: Record<string, number> = {};
for (const w of allWeapons) {
  const t = w.data.type;
  categoryCounts[t] = (categoryCounts[t] ?? 0) + 1;
}

const navTypes = [
  { key: 'all', label: 'All' },
  { key: 'pistol', label: 'Pistols' },
  { key: 'smg', label: 'SMGs' },
  { key: 'assault-rifle', label: 'Assault Rifles' },
  { key: 'shotgun', label: 'Shotguns' },
  { key: 'sniper-rifle', label: 'Snipers' },
  { key: 'lmg', label: 'LMGs' },
  { key: 'melee', label: 'Melee' },
  { key: 'throwable', label: 'Throwables' },
  { key: 'heavy', label: 'Heavy' },
];

const navCategories = navTypes
  .filter((t) => t.key === 'all' || categoryCounts[t.key] > 0)
  .map((t) => ({
    name: t.label,
    href: t.key === 'all' ? '/weapons/' : `/weapons/?type=${t.key}`,
    count: t.key === 'all' ? allWeapons.length : categoryCounts[t.key],
  }));

const filtered =
  filterParam === 'all' ? allWeapons : allWeapons.filter((w) => w.data.type === filterParam);

const currentLabel =
  filterParam === 'all'
    ? 'All'
    : navTypes.find((t) => t.key === filterParam)?.label ?? 'All';

const pageTitle = 'GTA 6 Weapons - Complete Weapon List | GTA6 Wikis';
const pageDescription =
  'Complete list of all weapons in GTA 6 — pistols, assault rifles, shotguns, snipers, melee weapons, throwables and heavy weapons.';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="page-container">
    <Breadcrumb items={[{ label: 'Weapons' }]} />

    <header class="page-header">
      <h1 class="page-title">GTA 6 Weapons</h1>
      <p class="page-subtitle">
        Every weapon in Grand Theft Auto VI — stats, categories, and real-world counterparts.
      </p>
    </header>

    <div class="filter-bar">
      <CategoryNav
        categories={navCategories}
        current={currentLabel}
        label="Weapon Categories"
      />
    </div>

    <div class="results-info">
      <span class="results-count">{filtered.length} weapons</span>
      {filterParam !== 'all' && (
        <a href="/weapons/" class="clear-filter">Clear filter ×</a>
      )}
    </div>

    <div class="card-grid" id="weapon-grid">
      {filtered.map((weapon, idx) => (
        <a
          href={`/weapons/${weapon.id}/`}
          class={`weapon-card${idx >= 12 ? ' card--hidden' : ''}`}
          data-card-index={idx}
        >
          <div class="weapon-card__icon-wrap">
            <span class="weapon-icon" aria-hidden="true">
              <Icon name={typeIcons[weapon.data.type] ?? 'weapons'} size={28} />
            </span>
            <span class="type-badge">{typeLabels[weapon.data.type] ?? weapon.data.type}</span>
          </div>
          <div class="weapon-card__body">
            <h3 class="weapon-card__name">{weapon.data.title}</h3>
            <p class="weapon-card__desc">{weapon.data.description}</p>
            {(weapon.data.damage !== undefined || weapon.data.accuracy !== undefined) && (
              <div class="stat-bars">
                {weapon.data.damage !== undefined && (
                  <div class="stat-bar">
                    <span class="stat-bar__label">Damage</span>
                    <div class="stat-bar__track">
                      <div class="stat-bar__fill stat-bar__fill--damage" style={`width: ${weapon.data.damage}%`} />
                    </div>
                    <span class="stat-bar__val">{weapon.data.damage}</span>
                  </div>
                )}
                {weapon.data.accuracy !== undefined && (
                  <div class="stat-bar">
                    <span class="stat-bar__label">Accuracy</span>
                    <div class="stat-bar__track">
                      <div class="stat-bar__fill" style={`width: ${weapon.data.accuracy}%`} />
                    </div>
                    <span class="stat-bar__val">{weapon.data.accuracy}</span>
                  </div>
                )}
                {weapon.data.fireRate !== undefined && (
                  <div class="stat-bar">
                    <span class="stat-bar__label">Fire Rate</span>
                    <div class="stat-bar__track">
                      <div class="stat-bar__fill stat-bar__fill--rate" style={`width: ${weapon.data.fireRate}%`} />
                    </div>
                    <span class="stat-bar__val">{weapon.data.fireRate}</span>
                  </div>
                )}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>

    {filtered.length > 12 && (
      <div class="load-more-wrap" id="load-more-wrap">
        <button class="btn-load-more" id="btn-load-more" type="button">
          Show all {filtered.length} weapons
        </button>
      </div>
    )}

    {filtered.length === 0 && (
      <div class="empty-state">
        <p>No weapons found for this category.</p>
        <a href="/weapons/" class="btn-reset">Show all weapons</a>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  /* Page-specific styles only — shared styles are in global.css */

  /* Weapons grid uses narrower min-width than default */
  .card-grid {
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: 16px;
  }

  .weapon-card {
    display: flex;
    align-items: flex-start;
    background: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .weapon-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(255, 94, 77, 0.12);
  }

  .weapon-card__icon-wrap {
    position: relative;
    width: 72px;
    min-width: 72px;
    height: 100%;
    min-height: 80px;
    background: var(--bg-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 6px;
    padding: 12px 8px;
  }

  .weapon-icon {
    width: 28px;
    height: 28px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--color-primary, #FF5E4D);
  }

  /* Weapon type-badge: smaller, accent-warm, no absolute position */
  .weapon-card .type-badge {
    font-size: 0.5625rem;
    padding: 2px 4px;
    background: var(--color-accent-warm);
    letter-spacing: 0.03em;
    word-break: break-word;
    max-width: 60px;
    text-align: center;
    border-radius: 3px;
  }

  .weapon-card__body {
    padding: 12px 14px;
    flex: 1;
    min-width: 0;
  }

  .weapon-card__name {
    font-size: 0.9rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 4px;
  }

  .weapon-card__desc {
    font-size: 0.8rem;
    color: var(--text-muted);
    margin: 0 0 10px;
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* Weapons stat bars: slightly tighter than vehicle version */
  .weapon-card .stat-bars { gap: 5px; }
  .weapon-card .stat-bar { gap: 6px; }
  .weapon-card .stat-bar__label { font-size: 0.625rem; }
  .weapon-card .stat-bar__track { height: 3px; }
  .weapon-card .stat-bar__fill { transition: none; }
  .weapon-card .stat-bar__val { font-size: 0.625rem; width: 20px; }

  .stat-bar__fill--damage { background: var(--color-accent-alt); }
  .stat-bar__fill--rate { background: var(--color-secondary); }

  @media (max-width: 480px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const btn = document.getElementById('btn-load-more');
  const wrap = document.getElementById('load-more-wrap');
  if (btn && wrap) {
    btn.addEventListener('click', () => {
      const hidden = document.querySelectorAll('#weapon-grid .card--hidden');
      hidden.forEach((el) => el.classList.remove('card--hidden'));
      wrap.remove();
    });
  }
</script>
