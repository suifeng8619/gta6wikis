---
import BaseLayout from '../components/layout/BaseLayout.astro';

const quickLinks = [
  { label: 'Characters', href: '/characters/', icon: '👤' },
  { label: 'Map', href: '/map/', icon: '🗺' },
  { label: 'Vehicles', href: '/vehicles/', icon: '🚗' },
  { label: 'Weapons', href: '/weapons/', icon: '🔫' },
];
---

<BaseLayout
  title="404 — Page Not Found | GTA6 Wikis"
  description="This page doesn't exist. Head back to the GTA6 Wikis homepage for characters, map, vehicles, weapons, and more."
>
  <section class="not-found-section">
    <div class="not-found-inner">

      <!-- 404 Headline -->
      <div class="headline-block" aria-hidden="true">
        <span class="headline-404">404</span>
      </div>

      <!-- Message -->
      <h1 class="page-title">Page Not Found</h1>
      <p class="page-subtitle">
        Looks like you took a wrong turn in Vice City
      </p>

      <!-- Search Box -->
      <form
        class="search-form"
        action="/search/"
        method="get"
        role="search"
        aria-label="Search GTA6 Wikis"
      >
        <label for="search-input" class="sr-only">Search GTA6 Wikis</label>
        <input
          id="search-input"
          type="search"
          name="q"
          class="search-input"
          placeholder="Search characters, weapons, vehicles…"
          autocomplete="off"
          autocorrect="off"
          spellcheck="false"
        />
        <button type="submit" class="search-btn" aria-label="Submit search">
          <svg width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
            <circle cx="8.5" cy="8.5" r="5.75" stroke="currentColor" stroke-width="1.75"/>
            <path d="M13.5 13.5L17.5 17.5" stroke="currentColor" stroke-width="1.75" stroke-linecap="round"/>
          </svg>
        </button>
      </form>

      <!-- Back to Home -->
      <a href="/" class="home-btn">
        Back to Home
      </a>

      <!-- Divider -->
      <div class="divider" aria-hidden="true"></div>

      <!-- Quick Links -->
      <nav aria-label="Explore GTA6 Wikis sections">
        <p class="quick-links-label">Or explore these sections:</p>
        <ul class="quick-links" role="list">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="quick-link">
                <span class="quick-link-icon" aria-hidden="true">{link.icon}</span>
                <span>{link.label}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

    </div>
  </section>
</BaseLayout>

<style>
  .not-found-section {
    min-height: calc(100vh - 120px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 3rem 1.5rem;
    background: var(--bg-primary);
  }

  .not-found-inner {
    max-width: 560px;
    width: 100%;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
  }

  /* 404 large number */
  .headline-block {
    line-height: 1;
    margin-bottom: 0.25rem;
  }

  .headline-404 {
    font-family: var(--font-display);
    font-size: clamp(7rem, 22vw, 11rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    background: linear-gradient(135deg, #FF5E4D 0%, #FF7A2D 50%, #FFB84D 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    display: block;
    user-select: none;
  }

  /* Title */
  .page-title {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 0.75rem;
    letter-spacing: 0.01em;
  }

  /* Subtitle */
  .page-subtitle {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    color: var(--text-secondary);
    margin: 0 0 2rem;
    line-height: 1.6;
  }

  /* Search form */
  .search-form {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 420px;
    border: 1.5px solid var(--border-strong);
    border-radius: 999px;
    overflow: hidden;
    background: var(--bg-surface);
    transition: border-color 0.2s;
    margin-bottom: 1.25rem;
  }

  .search-form:focus-within {
    border-color: #FF5E4D;
    outline: 2px solid rgba(255, 94, 77, 0.25);
    outline-offset: 0;
  }

  .search-input {
    flex: 1;
    border: none;
    outline: none;
    padding: 0.75rem 1.25rem;
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--text-primary);
    background: transparent;
  }

  .search-input::placeholder {
    color: var(--text-muted);
  }

  .search-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border: none;
    background: transparent;
    color: var(--text-muted);
    cursor: pointer;
    transition: color 0.15s;
    flex-shrink: 0;
  }

  .search-btn:hover {
    color: #FF5E4D;
  }

  /* Home button */
  .home-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.75rem 2rem;
    background: linear-gradient(135deg, #FF5E4D, #FFB84D);
    color: #1A0F0C;
    font-family: var(--font-display);
    font-size: 1.0625rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    border-radius: 999px;
    text-decoration: none;
    transition: opacity 0.2s, transform 0.15s;
    margin-bottom: 2rem;
  }

  .home-btn:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  .home-btn:focus-visible {
    outline: 3px solid #FF5E4D;
    outline-offset: 3px;
  }

  /* Divider */
  .divider {
    width: 100%;
    max-width: 320px;
    height: 1px;
    background: var(--border-default);
    margin-bottom: 1.5rem;
  }

  /* Quick links label */
  .quick-links-label {
    font-family: var(--font-body);
    font-size: 0.875rem;
    color: var(--text-muted);
    margin: 0 0 1rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }

  /* Quick links grid */
  .quick-links {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    justify-content: center;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .quick-link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.5rem 1.125rem;
    border: 1.5px solid var(--border-default);
    border-radius: 999px;
    color: var(--text-secondary);
    font-family: var(--font-body);
    font-size: 0.9rem;
    font-weight: 500;
    text-decoration: none;
    background: var(--bg-surface);
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }

  .quick-link:hover {
    border-color: #FF5E4D;
    color: #FF5E4D;
    background: rgba(255, 94, 77, 0.06);
  }

  .quick-link:focus-visible {
    outline: 2px solid #FF5E4D;
    outline-offset: 2px;
  }

  .quick-link-icon {
    font-size: 1em;
    line-height: 1;
  }

  /* Screen reader only */
  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Dark mode */
  :global(.dark) .not-found-section {
    background: var(--bg-primary);
  }

  :global(.dark) .search-form {
    background: #2A1A15;
    border-color: #5C3D35;
  }

  :global(.dark) .search-input {
    color: #FFF8F5;
  }

  :global(.dark) .quick-link {
    background: #2A1A15;
    border-color: #5C3D35;
  }
</style>
