---
import { getCollection } from 'astro:content';
import BaseLayout from '../../components/layout/BaseLayout.astro';
import Breadcrumb from '../../components/layout/Breadcrumb.astro';
import CategoryNav from '../../components/wiki/CategoryNav.astro';

const allVehicles = await getCollection('vehicles');
allVehicles.sort((a, b) => a.data.title.localeCompare(b.data.title));

// Category filter from URL
const filterParam = Astro.url.searchParams.get('type') ?? 'all';

// Type display label map
const typeLabels: Record<string, string> = {
  supercar: 'Supercars',
  sports: 'Sports',
  muscle: 'Muscle',
  sedan: 'Sedan',
  suv: 'SUV',
  compact: 'Compact',
  motorcycle: 'Motorcycles',
  boat: 'Boats',
  plane: 'Aircraft',
  helicopter: 'Aircraft',
  emergency: 'Emergency',
  commercial: 'Commercial',
  military: 'Military',
  special: 'Special',
  'public-transport': 'Public Transport',
};

// Counts per category key
const categoryCounts: Record<string, number> = {};
for (const v of allVehicles) {
  const t = v.data.type;
  categoryCounts[t] = (categoryCounts[t] ?? 0) + 1;
}

// Build nav categories
const navTypes = [
  { key: 'all', label: 'All' },
  { key: 'supercar', label: 'Supercars' },
  { key: 'muscle', label: 'Muscle' },
  { key: 'sports', label: 'Sports' },
  { key: 'suv', label: 'SUV' },
  { key: 'motorcycle', label: 'Motorcycles' },
  { key: 'boat', label: 'Boats' },
  { key: 'plane', label: 'Aircraft' },
  { key: 'emergency', label: 'Emergency' },
  { key: 'commercial', label: 'Commercial' },
];

const navCategories = navTypes
  .filter((t) => t.key === 'all' || categoryCounts[t.key] > 0)
  .map((t) => ({
    name: t.label,
    href: t.key === 'all' ? '/vehicles/' : `/vehicles/?type=${t.key}`,
    count: t.key === 'all' ? allVehicles.length : categoryCounts[t.key],
  }));

// Merge plane and helicopter under Aircraft nav
const aircraftTypes = ['plane', 'helicopter'];

function matchesFilter(type: string, filter: string): boolean {
  if (filter === 'all') return true;
  if (filter === 'plane') return aircraftTypes.includes(type);
  return type === filter;
}

const filtered = filterParam === 'all'
  ? allVehicles
  : allVehicles.filter((v) => matchesFilter(v.data.type, filterParam));

const currentLabel =
  filterParam === 'all'
    ? 'All'
    : navTypes.find((t) => t.key === filterParam)?.label ?? 'All';

const pageTitle = 'GTA 6 Vehicles - Complete Vehicle Database | GTA6 Wikis';
const pageDescription =
  'Browse every vehicle confirmed for GTA 6 — supercars, muscle cars, motorcycles, boats, aircraft, emergency vehicles and more.';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <div class="page-container">
    <Breadcrumb items={[{ label: 'Vehicles' }]} />

    <header class="page-header">
      <h1 class="page-title">GTA 6 Vehicles</h1>
      <p class="page-subtitle">
        Every confirmed vehicle in Grand Theft Auto VI — from supercars to aircraft.
      </p>
    </header>

    <div class="filter-bar">
      <CategoryNav
        categories={navCategories}
        current={currentLabel}
        label="Vehicle Categories"
      />
    </div>

    <div class="results-info">
      <span class="results-count">{filtered.length} vehicles</span>
      {filterParam !== 'all' && (
        <a href="/vehicles/" class="clear-filter">Clear filter ×</a>
      )}
    </div>

    <div class="card-grid" id="vehicle-grid">
      {filtered.map((vehicle, idx) => (
        <a
          href={`/vehicles/${vehicle.id}/`}
          class={`vehicle-card${idx >= 12 ? ' card--hidden' : ''}`}
          data-card-index={idx}
        >
          <div class="vehicle-card__thumb">
            <span class="vehicle-icon">&#9652;</span>
            <span class="type-badge">{typeLabels[vehicle.data.type] ?? vehicle.data.type}</span>
          </div>
          <div class="vehicle-card__body">
            <h3 class="vehicle-card__name">{vehicle.data.title}</h3>
            <p class="vehicle-card__maker">{vehicle.data.manufacturer}</p>
            <p class="vehicle-card__desc">{vehicle.data.description}</p>
            {(vehicle.data.speed !== undefined || vehicle.data.handling !== undefined) && (
              <div class="stat-bars">
                {vehicle.data.speed !== undefined && (
                  <div class="stat-bar">
                    <span class="stat-bar__label">Speed</span>
                    <div class="stat-bar__track">
                      <div class="stat-bar__fill" style={`width: ${vehicle.data.speed}%`} />
                    </div>
                    <span class="stat-bar__val">{vehicle.data.speed}</span>
                  </div>
                )}
                {vehicle.data.handling !== undefined && (
                  <div class="stat-bar">
                    <span class="stat-bar__label">Handling</span>
                    <div class="stat-bar__track">
                      <div class="stat-bar__fill" style={`width: ${vehicle.data.handling}%`} />
                    </div>
                    <span class="stat-bar__val">{vehicle.data.handling}</span>
                  </div>
                )}
              </div>
            )}
          </div>
        </a>
      ))}
    </div>

    {filtered.length > 12 && (
      <div class="load-more-wrap" id="load-more-wrap">
        <button class="btn-load-more" id="btn-load-more" type="button">
          Show all {filtered.length} vehicles
        </button>
      </div>
    )}

    {filtered.length === 0 && (
      <div class="empty-state">
        <p>No vehicles found for this category.</p>
        <a href="/vehicles/" class="btn-reset">Show all vehicles</a>
      </div>
    )}
  </div>
</BaseLayout>

<style>
  /* Page-specific styles only — shared styles are in global.css */

  .vehicle-card {
    display: flex;
    flex-direction: column;
    background: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-radius: 8px;
    overflow: hidden;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .vehicle-card:hover {
    border-color: var(--color-primary);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(255, 94, 77, 0.12);
  }

  .vehicle-card__thumb {
    position: relative;
    height: 100px;
    background: var(--bg-tertiary);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .vehicle-icon {
    font-size: 2.5rem;
    opacity: 0.25;
    color: var(--text-primary);
  }

  /* Override: position type-badge inside thumb */
  .vehicle-card .type-badge {
    position: absolute;
    top: 10px;
    right: 10px;
    padding: 3px 8px;
  }

  .vehicle-card__body {
    padding: 14px 16px 16px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .vehicle-card__name {
    font-size: 0.9375rem;
    font-weight: 700;
    color: var(--text-primary);
    margin: 0 0 2px;
  }

  .vehicle-card__maker {
    font-size: 0.8125rem;
    color: var(--color-secondary-dark);
    font-weight: 600;
    margin: 0 0 8px;
  }

  .vehicle-card__desc {
    font-size: 0.8125rem;
    color: var(--text-muted);
    margin: 0 0 12px;
    line-height: 1.5;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  @media (max-width: 480px) {
    .card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  const btn = document.getElementById('btn-load-more');
  const wrap = document.getElementById('load-more-wrap');
  if (btn && wrap) {
    btn.addEventListener('click', () => {
      const hidden = document.querySelectorAll('#vehicle-grid .card--hidden');
      hidden.forEach((el) => el.classList.remove('card--hidden'));
      wrap.remove();
    });
  }
</script>
