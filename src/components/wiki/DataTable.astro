---
/**
 * DataTable.astro — 数据表格
 *
 * Usage:
 * <DataTable
 *   headers={["武器", "伤害", "弹夹", "射速"]}
 *   rows={[
 *     ["手枪", "35", "12", "中"],
 *     ["步枪", "55", "30", "高"],
 *     ["散弹枪", "90", "8", "低"],
 *   ]}
 * />
 */

interface Props {
  headers: string[];
  rows: string[][];
  caption?: string;
}

const { headers, rows, caption } = Astro.props;
---

<div class="data-table-wrap" role="region" aria-label={caption ?? '数据表格'}>
  <div class="data-table-scroll">
    <table class="data-table">
      {caption && <caption class="data-table__caption">{caption}</caption>}
      <thead class="data-table__head">
        <tr>
          {headers.map((header) => (
            <th class="data-table__th" scope="col">{header}</th>
          ))}
        </tr>
      </thead>
      <tbody class="data-table__body">
        {rows.map((row, rowIndex) => (
          <tr class={`data-table__row ${rowIndex % 2 === 0 ? 'data-table__row--even' : 'data-table__row--odd'}`}>
            {row.map((cell, cellIndex) => (
              cellIndex === 0
                ? <th class="data-table__td data-table__td--first" scope="row">{cell}</th>
                : <td class="data-table__td">{cell}</td>
            ))}
          </tr>
        ))}
      </tbody>
    </table>
  </div>
</div>

<style>
  .data-table-wrap {
    width: 100%;
    margin: 1rem 0;
  }

  /* 响应式水平滚动容器 */
  .data-table-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--border-default);
    border-radius: 8px;
  }

  /* 自定义滚动条 */
  .data-table-scroll::-webkit-scrollbar {
    height: 6px;
  }
  .data-table-scroll::-webkit-scrollbar-track {
    background: var(--bg-secondary);
  }
  .data-table-scroll::-webkit-scrollbar-thumb {
    background: var(--border-strong);
    border-radius: 3px;
  }
  .data-table-scroll::-webkit-scrollbar-thumb:hover {
    background: var(--color-primary);
  }

  .data-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.875rem;
    white-space: nowrap;
  }

  .data-table__caption {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-align: left;
    padding: 8px 12px;
    caption-side: bottom;
    font-style: italic;
  }

  /* 表头 */
  .data-table__head {
    background: var(--bg-secondary);
  }

  .data-table__th {
    padding: 12px 16px;
    text-align: left;
    font-weight: 700;
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    color: var(--text-secondary);
    border-bottom: 2px solid var(--border-default);
    white-space: nowrap;
  }

  /* 表格行 */
  .data-table__row {
    transition: background 0.15s;
  }

  .data-table__row--even {
    background: var(--bg-surface);
  }

  .data-table__row--odd {
    background: var(--bg-tertiary);
  }

  .data-table__row:hover {
    background: var(--bg-secondary);
  }

  /* 表格单元格 */
  .data-table__td {
    padding: 10px 16px;
    color: var(--text-primary);
    border-bottom: 1px solid var(--border-default);
    vertical-align: middle;
  }

  .data-table__td--first {
    font-weight: 600;
    color: var(--text-secondary);
  }

  .data-table__row:last-child .data-table__td {
    border-bottom: none;
  }

  /* 允许长文本在小屏幕换行 */
  @media (max-width: 480px) {
    .data-table {
      white-space: normal;
    }
    .data-table__th,
    .data-table__td {
      padding: 8px 10px;
    }
  }
</style>
