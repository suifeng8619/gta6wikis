---
/**
 * TableOfContents.astro — 页内目录
 *
 * Usage:
 * <TableOfContents
 *   headings={[
 *     { depth: 2, slug: "intro", text: "简介" },
 *     { depth: 3, slug: "background", text: "背景故事" },
 *     { depth: 2, slug: "weapons", text: "武器" },
 *     { depth: 3, slug: "pistols", text: "手枪" },
 *     { depth: 4, slug: "pistol-list", text: "手枪列表" },
 *   ]}
 * />
 */

interface Heading {
  depth: number;
  slug: string;
  text: string;
}

interface Props {
  headings: Heading[];
  title?: string;
  sticky?: boolean;
}

const { headings, title = '目录', sticky = false } = Astro.props;

// 只展示 H2/H3/H4
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 4);

const tocId = `toc-${Math.random().toString(36).slice(2, 8)}`;
---

{filtered.length > 0 && (
  <nav
    class={`toc ${sticky ? 'toc--sticky' : ''}`}
    aria-label="页面目录"
    id={tocId}
  >
    <div class="toc__header">
      <h2 class="toc__title" id={`${tocId}-heading`}>{title}</h2>
      <button
        class="toc__toggle"
        aria-expanded="true"
        aria-controls={`${tocId}-list`}
        aria-label="折叠目录"
        type="button"
      >
        <span class="toc__toggle-icon" aria-hidden="true">▾</span>
      </button>
    </div>

    <ol class="toc__list" id={`${tocId}-list`} role="list" aria-labelledby={`${tocId}-heading`}>
      {filtered.map((heading) => (
        <li
          class={`toc__item toc__item--depth-${heading.depth}`}
          style={`padding-left: ${(heading.depth - 2) * 16}px`}
        >
          <a
            href={`#${heading.slug}`}
            class="toc__link"
            data-toc-target={heading.slug}
          >
            {heading.text}
          </a>
        </li>
      ))}
    </ol>
  </nav>
)}

<script define:vars={{ tocId }}>
  (function () {
    const nav = document.getElementById(tocId);
    if (!nav) return;

    /* ---- 折叠/展开 ---- */
    const toggle = nav.querySelector('.toc__toggle');
    const list   = nav.querySelector('.toc__list');

    if (toggle && list) {
      toggle.addEventListener('click', function () {
        const expanded = toggle.getAttribute('aria-expanded') === 'true';
        toggle.setAttribute('aria-expanded', String(!expanded));
        toggle.setAttribute('aria-label', expanded ? '展开目录' : '折叠目录');
        list.classList.toggle('toc__list--collapsed', expanded);
        const icon = toggle.querySelector('.toc__toggle-icon');
        if (icon) icon.textContent = expanded ? '▸' : '▾';
      });
    }

    /* ---- 当前章节高亮（IntersectionObserver） ---- */
    const links = Array.from(nav.querySelectorAll('.toc__link'));
    if (!links.length) return;

    const slugs = links.map(function (l) {
      return l.getAttribute('data-toc-target');
    });

    // 收集对应的标题元素
    const headingEls = slugs.map(function (slug) {
      return document.getElementById(slug);
    }).filter(Boolean);

    if (!headingEls.length) return;

    let activeSlug = null;

    const observer = new IntersectionObserver(
      function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            activeSlug = entry.target.id;
          }
        });

        // 更新高亮
        links.forEach(function (link) {
          const isActive = link.getAttribute('data-toc-target') === activeSlug;
          link.classList.toggle('toc__link--active', isActive);
          link.setAttribute('aria-current', isActive ? 'location' : 'false');
        });
      },
      {
        rootMargin: '-80px 0px -60% 0px',
        threshold: 0,
      }
    );

    headingEls.forEach(function (el) {
      observer.observe(el);
    });

    /* ---- 平滑滚动 ---- */
    links.forEach(function (link) {
      link.addEventListener('click', function (e) {
        const slug = link.getAttribute('data-toc-target');
        const target = document.getElementById(slug);
        if (target) {
          e.preventDefault();
          target.scrollIntoView({ behavior: 'smooth', block: 'start' });
          // 更新 URL hash（不跳转）
          history.pushState(null, '', '#' + slug);
        }
      });
    });
  })();
</script>

<style>
  .toc {
    background: var(--bg-surface);
    border: 1px solid var(--border-default);
    border-radius: 8px;
    overflow: hidden;
    font-size: 0.875rem;
    margin: 0 0 1.5rem 0;
  }

  .toc--sticky {
    position: sticky;
    top: 80px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
  }

  .toc--sticky::-webkit-scrollbar {
    width: 4px;
  }
  .toc--sticky::-webkit-scrollbar-thumb {
    background: var(--border-strong);
    border-radius: 2px;
  }

  .toc__header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 10px 14px;
    background: var(--bg-secondary);
    border-bottom: 1px solid var(--border-default);
  }

  .toc__title {
    font-family: var(--font-heading);
    font-size: 0.8125rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-secondary);
    margin: 0;
  }

  .toc__toggle {
    background: none;
    border: none;
    cursor: pointer;
    padding: 2px 6px;
    border-radius: 4px;
    color: var(--text-muted);
    font-size: 0.875rem;
    transition: color 0.15s, background 0.15s;
    line-height: 1;
  }

  .toc__toggle:hover {
    color: var(--color-primary);
    background: var(--bg-tertiary);
  }

  .toc__toggle:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 1px;
  }

  .toc__list {
    list-style: none;
    margin: 0;
    padding: 8px 0;
    transition: all 0.2s ease;
  }

  .toc__list--collapsed {
    display: none;
  }

  .toc__item {
    margin: 0;
  }

  .toc__link {
    display: block;
    padding: 5px 14px;
    color: var(--text-secondary);
    text-decoration: none;
    line-height: 1.5;
    border-left: 3px solid transparent;
    margin-left: 0;
    transition: color 0.15s, border-color 0.15s, background 0.15s;
    word-break: break-word;
  }

  .toc__link:hover {
    color: var(--color-primary);
    background: var(--bg-tertiary);
  }

  .toc__link:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: -2px;
  }

  /* 当前章节高亮 */
  .toc__link--active {
    color: var(--color-primary) !important;
    border-left-color: var(--color-primary) !important;
    background: rgba(255, 94, 77, 0.06);
    font-weight: 600;
  }

  /* H3 缩进样式 */
  .toc__item--depth-3 .toc__link {
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  /* H4 缩进样式 */
  .toc__item--depth-4 .toc__link {
    font-size: 0.75rem;
    color: var(--text-muted);
    font-style: italic;
  }
</style>
