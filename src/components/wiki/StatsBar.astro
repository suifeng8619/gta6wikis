---
/**
 * StatsBar.astro — 属性条/进度条（武器/载具属性展示）
 *
 * Usage:
 * <StatsBar label="伤害" value={85} />
 * <StatsBar label="射速" value={60} color="#39FF7A" />
 * <StatsBar label="精准度" value={92} color="#FFB84D" />
 */

interface Props {
  label: string;
  value: number;      // 0-100
  color?: string;     // 默认 var(--color-primary)
  showValue?: boolean;
}

const {
  label,
  value,
  color,
  showValue = true,
} = Astro.props;

// 限制 0-100
const clamped = Math.max(0, Math.min(100, value));
const colorStyle = color ? `background: ${color};` : '';
---

<div class="stats-bar" role="group" aria-label={`${label}: ${clamped}/100`}>
  <div class="stats-bar__header">
    <span class="stats-bar__label">{label}</span>
    {showValue && (
      <span class="stats-bar__number" aria-hidden="true">{clamped}</span>
    )}
  </div>
  <div
    class="stats-bar__track"
    role="progressbar"
    aria-valuenow={clamped}
    aria-valuemin={0}
    aria-valuemax={100}
  >
    <div
      class="stats-bar__fill"
      style={`width: ${clamped}%; ${colorStyle}`}
    />
  </div>
</div>

<style>
  .stats-bar {
    display: flex;
    flex-direction: column;
    gap: 6px;
    width: 100%;
  }

  .stats-bar__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .stats-bar__label {
    font-size: 0.8125rem;
    font-weight: 600;
    color: var(--text-secondary);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .stats-bar__number {
    font-family: var(--font-mono);
    font-size: 0.8125rem;
    font-weight: 700;
    color: var(--text-primary);
    min-width: 2.5ch;
    text-align: right;
  }

  .stats-bar__track {
    width: 100%;
    height: 8px;
    background: var(--bg-tertiary);
    border-radius: 9999px;
    overflow: hidden;
  }

  .stats-bar__fill {
    height: 100%;
    border-radius: 9999px;
    background: var(--color-primary);
    transition: width 0.6s cubic-bezier(0.4, 0, 0.2, 1);
    min-width: 2px;
  }

  /* 高值强调（>= 80 添加光晕） */
  .stats-bar__fill[style*="width: 8"],
  .stats-bar__fill[style*="width: 9"],
  .stats-bar__fill[style*="width: 10"] {
    box-shadow: 0 0 8px rgba(255, 94, 77, 0.50);
  }
</style>
