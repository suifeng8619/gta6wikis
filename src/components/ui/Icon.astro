---
/**
 * Icon.astro — Inline SVG icon component
 *
 * Usage:
 * <Icon name="characters" />
 * <Icon name="map" size={20} class="my-icon" />
 */

interface Props {
  name: string;
  size?: number;
  class?: string;
}

const { name, size = 24, class: className = '' } = Astro.props;

/**
 * All paths use viewBox="0 0 24 24", stroke style, currentColor.
 * Lucide-compatible line icons — no fill, no blue/purple.
 */
const icons: Record<string, string> = {
  // Characters — person silhouette
  characters: '<path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/>',

  // Map — pin / location marker
  map: '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',

  // Vehicles — car side view
  vehicles: '<path d="M5 17H3a2 2 0 0 1-2-2V9a2 2 0 0 1 2-2h13l4 4v4a2 2 0 0 1-2 2h-1"/><circle cx="7.5" cy="17" r="1.5"/><circle cx="17.5" cy="17" r="1.5"/><polyline points="10 9 10 7 14 7"/>',

  // Weapons — crosshair / target
  weapons: '<circle cx="12" cy="12" r="10"/><line x1="22" y1="12" x2="18" y2="12"/><line x1="6" y1="12" x2="2" y2="12"/><line x1="12" y1="6" x2="12" y2="2"/><line x1="12" y1="22" x2="12" y2="18"/><circle cx="12" cy="12" r="2"/>',

  // Radio — radio waves / signal
  radio: '<path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"/><path d="M19.1 4.9C23 8.8 23 15.1 19.1 19"/>',

  // Series — gamepad / controller
  series: '<line x1="6" y1="11" x2="10" y2="11"/><line x1="8" y1="9" x2="8" y2="13"/><line x1="15" y1="12" x2="15.01" y2="12"/><line x1="18" y1="10" x2="18.01" y2="10"/><path d="M17.32 5H6.68a4 4 0 0 0-3.978 3.59c-.006.052-.01.101-.017.152C2.604 9.416 2 14.456 2 16a3 3 0 0 0 3 3c1 0 1.5-.5 2-1l1.414-1.414A2 2 0 0 1 9.828 16h4.344a2 2 0 0 1 1.414.586L17 18c.5.5 1 1 2 1a3 3 0 0 0 3-3c0-1.544-.604-6.584-.685-7.258-.007-.05-.011-.1-.017-.151A4 4 0 0 0 17.32 5z"/>',

  // --- Weapon type icons ---

  // pistol — handgun side view
  pistol: '<path d="M6 12h12M6 12l-2 6h16l-2-6"/><path d="M10 12V8h4v4"/><path d="M8 12V7a1 1 0 0 1 1-1h6a1 1 0 0 1 1 1v5"/>',

  // smg — compact submachine gun
  smg: '<rect x="2" y="9" width="14" height="6" rx="1"/><path d="M16 11h3a1 1 0 0 1 1 1v2h-4"/><line x1="8" y1="9" x2="8" y2="6"/><line x1="5" y1="15" x2="5" y2="18"/>',

  // assault-rifle — rifle with magazine
  'assault-rifle': '<path d="M3 11h16a1 1 0 0 1 1 1v2a1 1 0 0 1-1 1H3a1 1 0 0 1-1-1v-2a1 1 0 0 1 1-1z"/><path d="M11 11V8"/><path d="M19 11l2-2"/><path d="M6 15l-2 3"/>',

  // shotgun — pump shotgun
  shotgun: '<path d="M2 12h18"/><path d="M18 9v6"/><path d="M15 10.5V8a1 1 0 0 1 1-1h3v6h-3a1 1 0 0 1-1-1v-2.5z"/><line x1="6" y1="12" x2="6" y2="15"/>',

  // sniper-rifle — scope crosshair
  'sniper-rifle': '<circle cx="12" cy="12" r="7"/><circle cx="12" cy="12" r="3"/><line x1="12" y1="2" x2="12" y2="5"/><line x1="12" y1="19" x2="12" y2="22"/><line x1="2" y1="12" x2="5" y2="12"/><line x1="19" y1="12" x2="22" y2="12"/>',

  // lmg — machine gun with bipod
  lmg: '<rect x="2" y="10" width="16" height="4" rx="1"/><path d="M18 11h2a1 1 0 0 1 1 1v2h-3"/><line x1="6" y1="14" x2="5" y2="18"/><line x1="10" y1="14" x2="10" y2="18"/>',

  // melee — crossed swords / fist
  melee: '<path d="M14.5 17.5L3 6V3h3l11.5 11.5"/><path d="M13 19l6-6"/><path d="M2 2l20 20"/><path d="M3 21l2.5-2.5"/>',

  // throwable — grenade shape
  throwable: '<circle cx="12" cy="13" r="7"/><path d="M12 6V2"/><path d="M10 2h4"/><line x1="9" y1="10" x2="15" y2="16"/>',

  // heavy — rocket / launcher
  heavy: '<path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>',

  // special — lightning bolt
  special: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',

  // --- AlertBox icons ---

  // info — circle with i
  info: '<circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/>',

  // warning — triangle with !
  warning: '<path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/>',

  // tip — lightbulb
  tip: '<line x1="9" y1="18" x2="15" y2="18"/><line x1="10" y1="22" x2="14" y2="22"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/>',

  // error — x circle
  error: '<circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/>',

  // success — check circle
  success: '<path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/>',
};
---
<svg
  xmlns="http://www.w3.org/2000/svg"
  width={size}
  height={size}
  viewBox="0 0 24 24"
  fill="none"
  stroke="currentColor"
  stroke-width="2"
  stroke-linecap="round"
  stroke-linejoin="round"
  class={className}
  aria-hidden="true"
  set:html={icons[name] ?? ''}
/>
