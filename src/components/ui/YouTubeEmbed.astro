---
interface Props {
  videoId: string;
  title: string;
  /** Optional: max width in px, default 800 */
  maxWidth?: number;
}
const { videoId, title, maxWidth = 800 } = Astro.props;
const thumbUrl = `https://i.ytimg.com/vi/${videoId}/maxresdefault.jpg`;
const embedId = `yt-${videoId}`;
---

<div class="yt-wrap" style={`max-width:${maxWidth}px`}>
  <div
    class="yt-embed"
    id={embedId}
    data-video-id={videoId}
    role="button"
    tabindex="0"
    aria-label={`Play ${title} on YouTube`}
  >
    <img
      src={thumbUrl}
      alt={title}
      loading="lazy"
      width="1280"
      height="720"
      decoding="async"
    />
    <div class="yt-overlay" aria-hidden="true"></div>
    <button class="yt-play" type="button" aria-label={`Play ${title}`} tabindex="-1">
      <svg viewBox="0 0 68 48" width="68" height="48" aria-hidden="true" focusable="false">
        <path
          d="M66.52 7.74c-.78-2.93-2.49-5.41-5.42-6.19C55.79.13 34 0 34 0S12.21.13 6.9 1.55C3.97 2.33 2.27 4.81 1.48 7.74.06 13.05 0 24 0 24s.06 10.95 1.48 16.26c.78 2.93 2.49 5.41 5.42 6.19C12.21 47.87 34 48 34 48s21.79-.13 27.1-1.55c2.93-.78 4.64-3.26 5.42-6.19C67.94 34.95 68 24 68 24s-.06-10.95-1.48-16.26z"
          fill="#FF5E4D"
        />
        <path d="M45 24L27 14v20" fill="#fff" />
      </svg>
    </button>
    <span class="yt-title" aria-hidden="true">{title}</span>
  </div>
</div>

<style>
  .yt-wrap {
    width: 100%;
    margin: 1.75rem auto;
  }

  .yt-embed {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    overflow: hidden;
    border-radius: 12px;
    cursor: pointer;
    background: #0a0a0a;
    border: 1px solid rgba(255, 255, 255, 0.08);
  }

  .yt-embed img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .yt-embed:hover img {
    transform: scale(1.02);
  }

  .yt-overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.3);
    transition: background 0.2s ease;
  }

  .yt-embed:hover .yt-overlay {
    background: rgba(0, 0, 0, 0.15);
  }

  .yt-play {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    line-height: 0;
    transition: transform 0.2s ease, filter 0.2s ease;
    filter: drop-shadow(0 4px 16px rgba(0, 0, 0, 0.6));
  }

  .yt-embed:hover .yt-play {
    transform: translate(-50%, -50%) scale(1.12);
    filter: drop-shadow(0 6px 20px rgba(255, 94, 77, 0.5));
  }

  .yt-title {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2rem 1.25rem 1rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: #fff;
    background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, transparent 100%);
    line-height: 1.4;
  }

  /* Active state: replace with iframe */
  .yt-embed.is-playing {
    padding-bottom: 56.25%;
  }

  .yt-embed.is-playing img,
  .yt-embed.is-playing .yt-overlay,
  .yt-embed.is-playing .yt-play,
  .yt-embed.is-playing .yt-title {
    display: none;
  }

  .yt-embed iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: 0;
    border-radius: 12px;
  }

  /* Focus ring for keyboard accessibility */
  .yt-embed:focus-visible {
    outline: 2px solid #FF5E4D;
    outline-offset: 3px;
  }
</style>

<script is:inline>
  (function () {
    function activateEmbed(el) {
      var id = el.dataset.videoId;
      if (!id) return;
      el.classList.add('is-playing');
      var iframe = document.createElement('iframe');
      iframe.src =
        'https://www.youtube-nocookie.com/embed/' +
        id +
        '?autoplay=1&rel=0&modestbranding=1';
      iframe.allow = 'autoplay; encrypted-media; picture-in-picture';
      iframe.allowFullscreen = true;
      iframe.title = el.getAttribute('aria-label') || 'YouTube video player';
      el.appendChild(iframe);
    }

    document.querySelectorAll('.yt-embed').forEach(function (el) {
      el.addEventListener('click', function () {
        activateEmbed(el);
      });
      el.addEventListener('keydown', function (e) {
        if (e.key === 'Enter' || e.key === ' ') {
          e.preventDefault();
          activateEmbed(el);
        }
      });
    });
  })();
</script>
