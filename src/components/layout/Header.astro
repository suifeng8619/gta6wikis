---
const navLinks = [
  { label: 'Characters', href: '/characters/' },
  { label: 'Map', href: '/map/' },
  { label: 'Vehicles', href: '/vehicles/' },
  { label: 'Weapons', href: '/weapons/' },
  { label: 'Radio', href: '/radio/' },
  { label: 'Guides', href: '/guides/' },
];

const currentPath = Astro.url.pathname;
---

<header class="site-header" role="banner">
  <nav class="navbar" aria-label="Main navigation">
    <!-- Logo -->
    <a href="/" class="navbar__logo" aria-label="GTA6 Wikis - Home">
      GTA6 WIKIS
    </a>

    <!-- Desktop Navigation -->
    <ul class="navbar__links" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class={`navbar__link${currentPath.startsWith(link.href) ? ' navbar__link--active' : ''}`}
            aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right Controls -->
    <div class="navbar__controls">
      <!-- Search Button -->
      <button
        class="navbar__icon-btn"
        aria-label="Search"
        type="button"
        id="search-trigger"
      >
        <svg
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
      </button>

      <!-- Dark Mode Toggle -->
      <button
        class="navbar__icon-btn"
        aria-label="Toggle dark mode"
        type="button"
        id="theme-toggle"
      >
        <!-- Sun icon (shown in dark mode) -->
        <svg
          class="theme-icon theme-icon--sun"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="5" />
          <line x1="12" y1="1" x2="12" y2="3" />
          <line x1="12" y1="21" x2="12" y2="23" />
          <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
          <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
          <line x1="1" y1="12" x2="3" y2="12" />
          <line x1="21" y1="12" x2="23" y2="12" />
          <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
          <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg
          class="theme-icon theme-icon--moon"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
      </button>

      <!-- Mobile Hamburger -->
      <button
        class="navbar__hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        type="button"
        id="hamburger-btn"
      >
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
        <span class="hamburger-bar"></span>
      </button>
    </div>
  </nav>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true" role="dialog" aria-label="Mobile navigation">
    <ul class="mobile-menu__links" role="list">
      {navLinks.map((link) => (
        <li>
          <a
            href={link.href}
            class={`mobile-menu__link${currentPath.startsWith(link.href) ? ' mobile-menu__link--active' : ''}`}
            aria-current={currentPath.startsWith(link.href) ? 'page' : undefined}
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</header>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
  }

  .navbar {
    height: 64px;
    padding: 0 24px;
    display: flex;
    align-items: center;
    gap: 32px;
    background: rgba(255, 248, 245, 0.95);
    backdrop-filter: blur(10px) saturate(180%);
    border-bottom: 1px solid var(--border-default);
    transition: background 0.3s ease, border-color 0.3s ease;
  }

  :global(.dark) .navbar {
    background: rgba(15, 10, 8, 0.95);
    border-bottom-color: var(--border-default);
  }

  /* Logo */
  .navbar__logo {
    font-family: var(--font-display);
    font-size: 24px;
    letter-spacing: 0.06em;
    background: linear-gradient(135deg, #FF5E4D 0%, #FFB84D 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    text-decoration: none;
    flex-shrink: 0;
    white-space: nowrap;
  }

  .navbar__logo:hover {
    background: linear-gradient(135deg, #FF2D78 0%, #FF5E4D 40%, #FFB84D 100%);
    -webkit-background-clip: text;
    background-clip: text;
  }

  /* Nav links */
  .navbar__links {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
    margin: 0;
    padding: 0;
    flex: 1;
  }

  .navbar__link {
    font-family: var(--font-heading);
    font-size: 14px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 6px 12px;
    border-radius: 6px;
    transition: color 0.2s ease, background 0.2s ease;
    white-space: nowrap;
  }

  .navbar__link:hover {
    color: #FF5E4D;
    background: rgba(255, 94, 77, 0.08);
  }

  .navbar__link--active {
    color: #FF5E4D;
    background: rgba(255, 94, 77, 0.1);
  }

  .navbar__link--active::after {
    content: '';
    display: block;
    height: 2px;
    background: linear-gradient(90deg, #FF5E4D, #FFB84D);
    border-radius: 1px;
    margin-top: 2px;
  }

  /* Right controls */
  .navbar__controls {
    display: flex;
    align-items: center;
    gap: 4px;
    margin-left: auto;
  }

  .navbar__icon-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 8px;
    background: transparent;
    color: var(--text-secondary);
    cursor: pointer;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .navbar__icon-btn:hover {
    color: #FF5E4D;
    background: rgba(255, 94, 77, 0.08);
  }

  /* Theme icons */
  .theme-icon--sun {
    display: none;
  }

  .theme-icon--moon {
    display: block;
  }

  :global(.dark) .theme-icon--sun {
    display: block;
  }

  :global(.dark) .theme-icon--moon {
    display: none;
  }

  /* Hamburger */
  .navbar__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 5px;
    width: 40px;
    height: 40px;
    border: none;
    border-radius: 8px;
    background: transparent;
    cursor: pointer;
    padding: 8px;
    transition: background 0.2s ease;
  }

  .navbar__hamburger:hover {
    background: rgba(255, 94, 77, 0.08);
  }

  .hamburger-bar {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-secondary);
    border-radius: 2px;
    transition: transform 0.3s ease, opacity 0.3s ease, background 0.2s ease;
  }

  .navbar__hamburger[aria-expanded="true"] .hamburger-bar:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
    background: #FF5E4D;
  }

  .navbar__hamburger[aria-expanded="true"] .hamburger-bar:nth-child(2) {
    opacity: 0;
  }

  .navbar__hamburger[aria-expanded="true"] .hamburger-bar:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
    background: #FF5E4D;
  }

  /* Mobile Menu */
  .mobile-menu {
    display: none;
    background: rgba(255, 248, 245, 0.98);
    backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--border-default);
    padding: 12px 16px 20px;
    transform: translateY(-100%);
    transition: transform 0.3s ease;
  }

  :global(.dark) .mobile-menu {
    background: rgba(15, 10, 8, 0.98);
  }

  .mobile-menu.is-open {
    transform: translateY(0);
  }

  .mobile-menu__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 4px;
  }

  .mobile-menu__link {
    display: block;
    font-family: var(--font-heading);
    font-size: 16px;
    font-weight: 500;
    color: var(--text-secondary);
    text-decoration: none;
    padding: 12px 16px;
    border-radius: 8px;
    transition: color 0.2s ease, background 0.2s ease;
  }

  .mobile-menu__link:hover {
    color: #FF5E4D;
    background: rgba(255, 94, 77, 0.08);
  }

  .mobile-menu__link--active {
    color: #FF5E4D;
    background: rgba(255, 94, 77, 0.1);
  }

  /* Responsive */
  @media (max-width: 768px) {
    .navbar__links {
      display: none;
    }

    .navbar__hamburger {
      display: flex;
    }

    .mobile-menu {
      display: block;
    }

    .navbar {
      gap: 16px;
    }
  }

  @media (max-width: 480px) {
    .navbar {
      padding: 0 16px;
    }
  }
</style>

<script>
  // Theme toggle
  const themeToggle = document.getElementById('theme-toggle');
  themeToggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    try {
      localStorage.setItem('theme', isDark ? 'dark' : 'light');
    } catch (e) {}
  });

  // Mobile hamburger
  const hamburgerBtn = document.getElementById('hamburger-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  hamburgerBtn?.addEventListener('click', () => {
    const isExpanded = hamburgerBtn.getAttribute('aria-expanded') === 'true';
    hamburgerBtn.setAttribute('aria-expanded', String(!isExpanded));
    mobileMenu?.setAttribute('aria-hidden', String(isExpanded));
    mobileMenu?.classList.toggle('is-open', !isExpanded);
  });

  // Close mobile menu on link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburgerBtn?.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
      mobileMenu.classList.remove('is-open');
    });
  });

  // Close mobile menu on outside click
  document.addEventListener('click', (e) => {
    const header = document.querySelector('.site-header');
    if (header && !header.contains(e.target as Node)) {
      hamburgerBtn?.setAttribute('aria-expanded', 'false');
      mobileMenu?.setAttribute('aria-hidden', 'true');
      mobileMenu?.classList.remove('is-open');
    }
  });
</script>
